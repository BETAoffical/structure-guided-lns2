{
  "schema_version": 1,
  "split": "confirmation",
  "solver_seed": 0,
  "environment": {
    "time_limit": 300.0,
    "max_repair_iterations": 100,
    "neighborhood_size": 8,
    "replan_algorithm": "PP",
    "use_sipp": true
  },
  "qualification": {
    "minimum_nonzero_states": 30,
    "minimum_nonzero_states_per_layout": 8,
    "minimum_active_maps": 10
  },
  "severity_thresholds": {"low_max": 0.001, "medium_max": 0.01},
  "proposal": {
    "max_seed_agents": 1,
    "heuristics": ["target", "collision", "random"],
    "neighborhood_sizes": [4],
    "trials": 2,
    "candidates_per_family": 1
  },
  "evaluation_trials": 2,
  "workers": 4,
  "baseline_wall_time_limit_seconds": 360.0,
  "proposal_wall_time_limit_seconds": 120.0,
  "trial_wall_time_limit_seconds": 120.0,
  "reference_datasets": [
    "build/repair-transfer-pilot-v2",
    "build/initlns-independent-layout-probe-v1"
  ]
}
