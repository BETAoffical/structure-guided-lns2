{
  "schema": "lns2.result_consolidation.v1",
  "schema_version": 1,
  "snapshot_date": "2026-07-17",
  "active_claim_zh": "基于当前动态冲突状态和实际 agent 邻域的 InitLNS 高层控制，在同族未见地图和多 solver seed 上得到闭环验证；标准 MovingAI 跨布局实验表现出广泛正信号，但未达到预注册的 5% 主门槛；静态地图、OD 和密度上下文的增量价值尚未得到证明。",
  "report_figure_prefix": "../artifacts/initlns-research-evidence-v1/figures",
  "research_boundary": {
    "phase": "InitLNS first-feasible repair",
    "static_context_increment_confirmed": false,
    "same_family_generalization_confirmed": true,
    "movingai_cross_layout_confirmed": false,
    "rl_trained": false,
    "autoregressive_agent_subset_trained": false
  },
  "solver_baseline": {
    "upstream": "Jiaoyang-Li/MAPF-LNS2",
    "upstream_commit": "1369823985a15944f9a339226d521f61605a6d17",
    "parity_source": "CMakeLists.txt",
    "expected_path_sha256": "915ee104f0168c463f05925541fef1c22ec1eb37e9bf8df7ab09807753013ecf"
  },
  "related_work": [
    {
      "name": "MAPF-ML-LNS",
      "url": "https://ojs.aaai.org/index.php/AAAI/article/view/21168",
      "method_zh": "监督排序由规则生成的候选 agent 集合，主要优化已有可行解的 cost",
      "boundary_zh": "最接近显式邻域排序，但不是 InitLNS 首次可行修复"
    },
    {
      "name": "NNS",
      "url": "https://proceedings.iclr.cc/paper_files/paper/2024/hash/d41f8403e9bb5141bc2c81fad7658185-Abstract-Conference.html",
      "method_zh": "卷积与注意力编码路径时空交互并选择邻域",
      "boundary_zh": "表示更强，研究阶段和跨尺寸迁移边界不同"
    },
    {
      "name": "BALANCE",
      "url": "https://arxiv.org/abs/2312.16767",
      "method_zh": "非上下文 bandit 联合选择 destroy heuristic 与邻域大小",
      "boundary_zh": "动作维度相近，但面向 anytime LNS 且不读取丰富当前状态"
    },
    {
      "name": "ADDRESS",
      "url": "https://arxiv.org/abs/2408.02960",
      "method_zh": "delay 启发式与 Thompson sampling 选择 seed",
      "boundary_zh": "使用动态 delay，但没有显式候选集合排序"
    },
    {
      "name": "LNS2+RL",
      "url": "https://arxiv.org/abs/2405.17794",
      "method_zh": "RL 替换早期低层 repair planner，之后切回 PP+SIPPS",
      "boundary_zh": "修改低层修复器，不是高层 agent 邻域选择"
    },
    {
      "name": "DiffLNS",
      "url": "https://arxiv.org/abs/2605.13296",
      "method_zh": "扩散模型生成更好的初始化路径，再交给 LNS2",
      "boundary_zh": "改进初始化而非 InitLNS 高层修复动作"
    }
  ],
