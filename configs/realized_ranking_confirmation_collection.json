{
  "schema_version": 1,
  "split": "confirmation",
  "solver_seed": 0,
  "environment": {
    "time_limit": 300.0,
    "max_repair_iterations": 100,
    "neighborhood_size": 8,
    "replan_algorithm": "PP",
    "use_sipp": true
  },
  "qualification": {
    "minimum_initial_conflicts": 1,
    "maximum_initial_conflicts": 200,
    "maximum_agent_count": 100,
    "minimum_repairable_tasks": 36,
    "minimum_repairable_tasks_per_layout": 12,
    "require_paired_od_and_density_per_map": true
  },
  "proposal": {
    "max_seed_agents": 4,
    "heuristics": ["target", "collision", "random"],
    "neighborhood_sizes": [4, 8, 16],
    "trials": 8,
    "candidates_per_family": 2
  },
  "evaluation_trials": 8,
  "workers": 4,
  "episode_wall_time_limit_seconds": 300.0,
  "reference_datasets": [
    "build/repair-transfer-pilot-v2",
    "build/initlns-independent-layout-probe-v1"
  ]
}
